# Copy this file to terraform.tfvars and fill in your values
# terraform.tfvars is gitignored — never commit real values

region         = "us-east-1"
cluster_name   = "eks-test-cluster"
loki_s3_bucket = "your-loki-storage-bucket-name"

# Set to true when deploying the EKS cluster (creates NAT gateway for private subnets)
# Set to false to create only the VPC structure (free)
create_nat_gateway = true
